# ===============================
# JSMail v2 Environment Variables
# ===============================

# 🔐 Master login code (dashboard access)
MASTER_CODE=your_super_secret_code

# ===============================
# 📦 MongoDB
# ===============================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/jsmail

# ===============================
# 📧 Resend Email API
# ===============================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
EMAIL_FROM=Jitendra Singh <you@jitendrasingh.online>

# ===============================
# 🔔 Push Notifications (VAPID)
# ===============================
VAPID_SUBJECT=mailto:you@jitendrasingh.online
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_public_key
VAPID_PRIVATE_KEY=your_private_key

# ===============================
# ☁️ Vercel Blob (attachments)
# ===============================
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxx

# ===============================
# 🌐 App URL
# ===============================
PUBLIC_APP_URL=https://mails.jitendrasingh.online

# ===============================
# 🛡 Optional
# ===============================
NODE_ENV=production